NODE_ENV=production
PORT=3010
PUBLIC_BASE_DOMAIN=hcasc.cz
DATABASE_URL=postgres://kcml:change-me@localhost:5432/kcml
ACCESS_TOKEN_HMAC_KEY_BASE64=replace-with-32-random-bytes-base64
ACCESS_TOKEN_HMAC_KEY_ID=v1
SESSION_SECRET_BASE64=replace-with-32-random-bytes-base64
CSRF_SECRET_BASE64=replace-with-32-random-bytes-base64
MFA_ENCRYPTION_KEY_BASE64=replace-with-32-random-bytes-base64
# Required to activate admin login together with PASS during production deploy.
ADMIN_TOTP_SECRET=replace-with-totp-secret-from-secure-channel
ADMIN_HOST=admin.hcasc.cz
AUTH_HOST=auth.hcasc.cz
LOG_LEVEL=info
