NODE_ENV=production
PORT=3010
PUBLIC_BASE_DOMAIN=hcasc.cz
DATABASE_URL=postgres://kcml:change-me@localhost:5432/kcml
ACCESS_TOKEN_HMAC_KEY_BASE64=replace-with-32-random-bytes-base64
ACCESS_TOKEN_HMAC_KEY_ID=v1
INTEGRATION_TOKEN_HMAC_KEY_BASE64=replace-with-a-different-32-random-bytes-base64
INTEGRATION_TOKEN_HMAC_KEY_ID=v1
EGRESS_CAPABILITY_HMAC_KEY_BASE64=replace-with-a-third-32-random-bytes-base64
SESSION_SECRET_BASE64=replace-with-32-random-bytes-base64
CSRF_SECRET_BASE64=replace-with-32-random-bytes-base64
MFA_ENCRYPTION_KEY_BASE64=replace-with-32-random-bytes-base64
# Required to activate admin login together with PASS during production deploy.
ADMIN_TOTP_SECRET=replace-with-totp-secret-from-secure-channel
ADMIN_HOST=admin.hcasc.cz
AUTH_HOST=auth.hcasc.cz
REGISTER_HOST=register.hcasc.cz
QUARANTINE_ROOT=/var/lib/kcml/onboarding
ONBOARDING_WORKER_ENABLED=true
ONBOARDING_WORKER_INTERVAL_MS=15000
# GitHub API authorization: use an existing repository-capable token, or leave it
# empty and configure all three GitHub App values below.
GITHUB_OWNER=karelmartinek-a11y
GITHUB_REPO=KajovoMCPCML
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
OCI_REGISTRY=ghcr.io
OCI_IMAGE_NAMESPACE=karelmartinek-a11y/kajovomcpcml-handlers
OCI_SIGNING_PUBLIC_KEY=/etc/kcml/cosign.pub
PODMAN_BINARY=podman
COSIGN_BINARY=cosign
RUNTIME_SOCKET_ROOT=/var/lib/kcml/runtime
EGRESS_PROXY_SOCKET_PATH=/var/lib/kcml/egress/proxy.sock
WILDCARD_TLS_CERT_PATH=/etc/letsencrypt/live/wildcard.hcasc.cz/fullchain.pem
LOG_LEVEL=info
