{
  "name": "@hcasc/home-assistant-device-catalog",
  "version": "2.0.5",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json"
  },
  "eslintConfig": {
    "env": {
      "es2022": true,
      "node": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    }
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "eslint": "8.57.1",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
