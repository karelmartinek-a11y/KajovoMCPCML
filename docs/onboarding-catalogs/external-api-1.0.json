{
  "version": "1.0",
  "serviceKind": "EXTERNAL_API",
  "manifestSchemaVersion": "1.0",
  "canonicalDigest": "sha256:pending-generated-at-runtime",
  "manifestExamplePath": "docs/service-manifest-external-api-v1.0.example.json",
  "requiredArtifacts": [
    "manifest",
    "contractEvidence",
    "securityEvidence",
    "runbookEvidence"
  ],
  "gateRules": [
    "G01_SCHEMA",
    "G02_INTENT_BINDING",
    "G03_OWNERSHIP",
    "G04_ARTIFACT_INTEGRITY",
    "G05_ENDPOINT_SAFETY",
    "G06_AUTH_ACCEPTANCE",
    "G07_SCOPE_ENFORCEMENT",
    "G08_STATE_CONTRACTS",
    "G09_LOGGING",
    "G10_MONITORING",
    "G11_DISABLE_ENFORCEMENT",
    "G12_PERMISSION_MUTATION",
    "G13_RESILIENCE",
    "G14_REGISTRATION_FINALIZATION"
  ],
  "errorCodes": [
    "INVALID_EXTERNAL_API_MANIFEST",
    "INVALID_INTEGRATION_TOKEN",
    "IDEMPOTENCY_KEY_REUSED",
    "UNSAFE_ENDPOINT",
    "AUTH_ACCEPTANCE_FAILED",
    "LOGGING_CONTRACT_FAILED",
    "MONITORING_CONTRACT_FAILED",
    "EXTERNAL_API_PROBE_FAILED"
  ],
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "KCML EXTERNAL_API registration manifest v1.0",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schemaVersion",
      "serviceKind",
      "environment",
      "registrationRevision",
      "displayName",
      "description",
      "serviceIdentity",
      "owners",
      "contacts",
      "governance",
      "review",
      "auth",
      "endpoints",
      "operations",
      "rateLimit",
      "timeoutMs",
      "monitoringProfile",
      "loggingContract",
      "stateContract",
      "egressPolicy",
      "errorCatalog",
      "evidence"
    ],
    "properties": {
      "schemaVersion": { "const": "1.0" },
      "serviceKind": { "const": "EXTERNAL_API" },
      "environment": { "enum": ["production", "staging"] },
      "registrationRevision": { "type": "string", "minLength": 3, "maxLength": 80 },
      "displayName": { "type": "string", "minLength": 3, "maxLength": 120 },
      "description": { "type": "string", "minLength": 20, "maxLength": 2000 },
      "serviceIdentity": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "region", "basePath"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,62}$" },
          "region": { "type": "string", "minLength": 2, "maxLength": 80 },
          "basePath": { "type": "string", "pattern": "^/" }
        }
      },
      "owners": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "technical", "security", "operations"],
        "properties": {
          "service": { "type": "string" },
          "technical": { "type": "string" },
          "security": { "type": "string" },
          "operations": { "type": "string" }
        }
      },
      "contacts": {
        "type": "object",
        "additionalProperties": false,
        "required": ["serviceEmail", "technicalEmail", "securityEmail", "operationsOnCall"],
        "properties": {
          "serviceEmail": { "type": "string", "format": "email" },
          "technicalEmail": { "type": "string", "format": "email" },
          "securityEmail": { "type": "string", "format": "email" },
          "operationsOnCall": { "type": "string", "minLength": 5 }
        }
      },
      "governance": { "type": "object" },
      "review": { "type": "object" },
      "auth": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "tokenEndpointUrl", "jwksUrl", "authMetadataUrl", "gatewayEnforced"],
        "properties": {
          "mode": { "const": "NONE" },
          "tokenEndpointUrl": { "type": "null" },
          "jwksUrl": { "type": "null" },
          "authMetadataUrl": { "type": "null" },
          "gatewayEnforced": { "const": true }
        }
      },
      "endpoints": { "type": "object" },
      "operations": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operationId",
            "method",
            "path",
            "requiredScopes",
            "idempotency",
            "requestSchema",
            "responseSchema",
            "timeoutMs",
            "maxPayloadBytes"
          ],
          "properties": {
            "operationId": { "type": "string" },
            "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
            "path": { "type": "string", "pattern": "^/" },
            "requiredScopes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "idempotency": { "enum": ["READ_ONLY", "IDEMPOTENT", "NON_IDEMPOTENT"] },
            "requestSchema": { "type": "object" },
            "responseSchema": { "type": "object" },
            "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 60000 },
            "maxPayloadBytes": { "type": "integer", "minimum": 1, "maximum": 5242880 }
          }
        }
      },
      "rateLimit": { "type": "object" },
      "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 60000 },
      "monitoringProfile": { "type": "object" },
      "loggingContract": { "type": "object" },
      "stateContract": { "type": "object" },
      "egressPolicy": { "type": "object" },
      "errorCatalog": { "type": "array", "minItems": 1, "items": { "type": "object" } },
      "evidence": { "type": "object" }
    }
  },
  "programmerApi": {
    "openapi": "3.1.0",
    "info": {
      "title": "KCML service onboarding programmer API",
      "version": "1.0"
    },
    "servers": [
      {
        "url": "https://{registerHost}",
        "variables": {
          "registerHost": {
            "default": "register.hcasc.cz"
          }
        }
      }
    ],
    "paths": {
      "/v1/service-onboardings": {
        "post": {
          "summary": "Register an EXTERNAL_API managed service revision",
          "parameters": [
            {
              "name": "Idempotency-Key",
              "in": "header",
              "required": true,
              "schema": {
                "type": "string",
                "minLength": 8,
                "maxLength": 128
              }
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/externalApiManifest"
                }
              }
            }
          },
          "responses": {
            "202": {
              "description": "Registration completed into REGISTERED_DISABLED",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/onboardingReceipt"
                  }
                }
              }
            }
          }
        }
      },
      "/v1/service-onboardings/{id}": {
        "get": {
          "summary": "Read the current onboarding job state"
        }
      },
      "/v1/service-onboardings/{id}/revision": {
        "put": {
          "summary": "Upload a corrected EXTERNAL_API manifest revision",
          "parameters": [
            {
              "name": "Idempotency-Key",
              "in": "header",
              "required": true,
              "schema": {
                "type": "string",
                "minLength": 8,
                "maxLength": 128
              }
            },
            {
              "name": "If-Match",
              "in": "header",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ]
        }
      },
      "/v1/service-onboardings/{id}/cancel": {
        "post": {
          "summary": "Cancel the active onboarding job"
        }
      }
    },
    "components": {
      "schemas": {
        "externalApiManifest": {
          "$ref": "#/../jsonSchema"
        },
        "onboardingReceipt": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "jobId": { "type": "string", "format": "uuid" },
            "lockVersion": { "type": "integer" },
            "serviceId": { "type": ["string", "null"], "format": "uuid" },
            "revisionId": { "type": ["string", "null"], "format": "uuid" },
            "finalState": { "type": "string" },
            "correlationId": { "type": "string", "format": "uuid" }
          }
        }
      }
    }
  }
}
