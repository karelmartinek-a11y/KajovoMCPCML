[Service]
Environment=XDG_RUNTIME_DIR=/run/kcml-podman
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/kcml-podman/bus
# ProtectHome=true hides /run/user from the worker's mount namespace. Mount
# only this service account's runtime at a dedicated visible path instead.
RuntimeDirectory=kcml-podman
RuntimeDirectoryMode=0700
BindPaths=/run/user/@KCML_UID@:/run/kcml-podman
ReadWritePaths=/run/kcml-podman
