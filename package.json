{
  "name": "kajovocml",
  "version": "2026.7.22-compliance.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @kcml/admin-ui build && pnpm --filter @kcml/server dev",
    "lint": "eslint .",
    "postinstall": "node scripts/clean-appledouble.mjs",
    "catalog:generate": "node scripts/generate-mcp-onboarding-catalog.mjs",
    "catalog:check": "node scripts/generate-mcp-onboarding-catalog.mjs --check",
    "repository-catalog:generate": "node scripts/generate-repository-component-catalog.mjs",
    "repository-catalog:check": "node scripts/generate-repository-component-catalog.mjs --check",
    "repository-change-routing:check": "node scripts/test-repository-component-change-classifier.mjs",
    "repository-deploy-receipt:check": "node scripts/test-repository-component-deploy-receipt.mjs",
    "repository-finalizer:check": "node scripts/test-repository-component-finalizer.mjs",
    "repository-workflows:check": "bash scripts/test-repository-component-workflows.sh",
    "repository-deploy:check": "bash scripts/test-repository-component-deploy.sh",
    "repository-attestations:check": "node scripts/test-repository-component-attestations.mjs",
    "repository-validator:check": "node scripts/test-repository-component-validator.mjs",
    "repository-components:check": "node scripts/validate-repository-components.mjs",
    "pretest": "node scripts/clean-appledouble.mjs && node scripts/generate-mcp-onboarding-catalog.mjs --check && node scripts/generate-repository-component-catalog.mjs --check && node scripts/validate-repository-components.mjs && node scripts/test-repository-component-change-classifier.mjs && node scripts/test-repository-component-deploy-receipt.mjs && node scripts/test-repository-component-finalizer.mjs && node scripts/test-repository-component-validator.mjs && bash scripts/test-repository-component-workflows.sh && bash scripts/test-repository-component-deploy.sh && node scripts/test-repository-component-attestations.mjs",
    "test": "vitest run --exclude '**/._*' --exclude 'components/**'",
    "typecheck": "pnpm -r typecheck",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:migrate": "pnpm --filter @kcml/server db:migrate",
    "admin:sync-password": "pnpm --filter @kcml/server admin:sync-password"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "ajv": "^8.20.0",
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "argon2": "^0.41.1"
  },
  "packageManager": "pnpm@11.7.0"
}
