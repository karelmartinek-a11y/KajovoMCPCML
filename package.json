{
  "name": "kajovomcpcml",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @kcml/server dev",
    "lint": "eslint .",
    "test": "vitest run --exclude '**/._*'",
    "typecheck": "pnpm -r typecheck",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:migrate": "pnpm --filter @kcml/server db:migrate",
    "admin:sync-password": "pnpm --filter @kcml/server admin:sync-password"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.30.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "argon2": "^0.41.1"
  },
  "packageManager": "pnpm@9.15.4"
}
